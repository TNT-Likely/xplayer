---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/strings';

const locale = 'zh' as const;
const tr = t(locale);
const p = tr.support;
---

<Layout title={p.title} description={p.intro} locale={locale} pathname="/zh/support">
  <h1>{p.title}</h1>
  <p class="subtitle">{p.lastUpdated}</p>
  <p>{p.intro}</p>

  {p.sections.map((s) => (
    <>
      <h2>{s.h}</h2>
      <p>{s.p}</p>
    </>
  ))}

  <h2>{p.contact.h}</h2>
  <p class="note">
    {p.contact.p}<br />
    ✉️ <a href={`mailto:${p.contact.email}`}>{p.contact.email}</a>
    {' · '}
    <a href={p.contact.github}>{p.contact.githubLabel}</a>
  </p>

  <p class="stamp">© {new Date().getFullYear()} {tr.site.brand}</p>
</Layout>
