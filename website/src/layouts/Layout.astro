---
import { t, type Locale } from '../i18n/strings';

interface Props {
  title: string;
  description?: string;
  locale: Locale;
  pathname: string;
}

const { title, description = '', locale, pathname } = Astro.props;
const tr = t(locale);
const base = locale === 'zh' ? '/zh' : '';
const nav = [
  { href: `${base}/`, label: tr.nav.home },
  { href: `${base}/privacy`, label: tr.nav.privacy },
  { href: `${base}/terms`, label: tr.nav.terms },
  { href: `${base}/support`, label: tr.nav.support },
];
const norm = (p: string) => (p.length > 1 ? p.replace(/\/$/, '') : p);
const here = norm(pathname);
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} · {tr.site.brand}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={`${title} · ${tr.site.brand}`} />
    {description && <meta property="og:description" content={description} />}
    <meta property="og:type" content="website" />
    <link rel="icon" href="/icon.png" type="image/png" />
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={`${base}/`}><img src="/logo.png" alt={tr.site.brand} /></a>
      <nav>
        {nav.map((n) => (
          <a href={n.href} class:list={[{ active: norm(n.href) === here }]}>{n.label}</a>
        ))}
        <a class="lang" href={tr.site.langSwitchHref}>{tr.site.langSwitchLabel}</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="links">
        <a href={tr.site.repo}>GitHub</a>
        <a href={`${base}/privacy`}>{tr.nav.privacy}</a>
        <a href={`${base}/terms`}>{tr.nav.terms}</a>
        <a href={`${base}/support`}>{tr.nav.support}</a>
      </div>
      <p class="note">{tr.footer.note}</p>
      <p class="meta">© {new Date().getFullYear()} {tr.site.brand} · {tr.footer.license} · {tr.footer.builtWith}</p>
    </footer>

    <style is:global>
      :root {
        --bg: #0f1115;
        --surface: #171a21;
        --border: #262b36;
        --text: #e8eaed;
        --muted: #9aa3b2;
        --brand: #22c55e;
        --maxw: 880px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font: 16px/1.7 -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto,
          'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--brand); text-decoration: none; }
      a:hover { text-decoration: underline; }

      .site-header {
        display: flex; align-items: center; justify-content: space-between;
        gap: 16px; flex-wrap: wrap;
        max-width: var(--maxw); margin: 0 auto; padding: 18px 20px;
      }
      .brand { display: inline-flex; align-items: center; }
      .brand img { height: 30px; display: block; }
      .hero-logo { height: 76px; display: block; margin-bottom: 10px; }
      .site-header nav { display: flex; gap: 18px; align-items: center; flex-wrap: wrap; }
      .site-header nav a { color: var(--muted); font-size: 15px; }
      .site-header nav a.active { color: var(--text); }
      .site-header nav a.lang {
        color: var(--text); border: 1px solid var(--border);
        border-radius: 999px; padding: 3px 12px; font-size: 13px;
      }

      main { max-width: var(--maxw); margin: 0 auto; padding: 24px 20px 64px; }
      h1 { font-size: 30px; line-height: 1.25; margin: 8px 0 12px; }
      h2 { font-size: 20px; margin: 32px 0 8px; }
      p { color: var(--text); }
      .subtitle { color: var(--muted); margin-top: 0; }
      .note {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: 12px; padding: 14px 16px; color: var(--muted);
      }
      .stamp { color: var(--muted); margin-top: 40px; font-size: 14px; }

      /* landing */
      .hero { padding: 28px 0 8px; }
      .hero h1 { font-size: 38px; }
      .hero p { color: var(--muted); font-size: 18px; max-width: 640px; }
      .platforms { color: var(--muted); font-size: 14px; margin-top: 4px; }
      .cta { display: flex; gap: 12px; flex-wrap: wrap; margin: 22px 0 8px; }
      .btn {
        display: inline-block; padding: 11px 22px; border-radius: 999px;
        font-weight: 600; font-size: 15px;
      }
      .btn.primary { background: var(--brand); color: #062611; }
      .btn.primary:hover { text-decoration: none; opacity: .92; }
      .btn.ghost { border: 1px solid var(--border); color: var(--text); }
      .btn.ghost:hover { text-decoration: none; border-color: var(--brand); }

      .features { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px; margin-top: 12px; }
      .feature { background: var(--surface); border: 1px solid var(--border); border-radius: 14px; padding: 18px; }
      .feature h3 { margin: 0 0 6px; font-size: 16px; }
      .feature p { color: var(--muted); margin: 0; font-size: 14px; }

      .shots { display: flex; gap: 20px; flex-wrap: wrap; justify-content: center; margin-top: 12px; }
      .shot { text-align: center; }
      .shot img {
        width: 240px; max-width: 70vw; border-radius: 18px;
        border: 1px solid var(--border); box-shadow: 0 10px 30px rgba(0,0,0,.4);
      }
      .shot figcaption { color: var(--muted); font-size: 13px; margin-top: 8px; }

      .site-footer {
        border-top: 1px solid var(--border);
        max-width: var(--maxw); margin: 0 auto; padding: 28px 20px 48px;
        color: var(--muted);
      }
      .site-footer .links { display: flex; gap: 18px; flex-wrap: wrap; }
      .site-footer .links a { color: var(--muted); font-size: 14px; }
      .site-footer .note { font-size: 13px; margin: 14px 0 4px; }
      .site-footer .meta { font-size: 13px; margin: 0; }
    </style>
  </body>
</html>
